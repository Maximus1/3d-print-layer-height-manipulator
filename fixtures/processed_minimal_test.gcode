; FIXTURE: minimal_test.gcode
; Alle kritischen Parser-Fälle
; Generiert für Parser-Tests

; ============================================================
; 1. HEADER / KOMMENTARE
; ============================================================
; generated by PrusaSlicer 2.6.0
; layer_height: 0.1
; filament_diameter: 1.75
M82 ; use absolute extrusion
G21 ; set units to millimeters
G90 ; use absolute coordinates
M104 S200 ; set temperature
G28 ; home all axes

; ============================================================
; 2. LAYER 1 - Basis
; ============================================================
;LAYER_CHANGE
; layer:1
; TYPE:SKIN
G1 X10 Y10 Z0.3 F3000 E0.5
G1 X20 Y10 Z0.3 E1.0
G1 X20 Y20 Z0.3 E1.5
G1 X10 Y20 Z0.3 E2.0
G1 X10 Y10 Z0.3 E2.5

; ============================================================
; 3. TRAVEL (G0) - KEIN E
; ============================================================
;TYPE:WALL-OUTER
G0 X15 Y15 Z0.4 F6000
G1 X25 Y15 Z0.4 E3.0
G1 X25 Y25 Z0.4 E3.5
G1 X15 Y25 Z0.4 E4.0
G1 X15 Y15 Z0.4 E4.5

; ============================================================
; 4. RELATIVE EXTRUSION (M83)
; ============================================================
M83 ; switch to relative extrusion
G1 X10 Y10 Z0.5 E0.3
G1 X20 Y10 Z0.5 E0.3
G1 X20 Y20 Z0.5 E0.3
G1 X10 Y20 Z0.5 E0.3

; ============================================================
; 5. ABSOLUTE EXTRUSION ZURÜCK (M82)
; ============================================================
M82 ; switch back to absolute extrusion
G1 X10 Y10 Z0.6 E5.0
G1 X30 Y10 Z0.6 E6.0
G1 X30 Y30 Z0.6 E7.0
G1 X10 Y30 Z0.6 E8.0

; ============================================================
; 6. G92 E0 RESET
; ============================================================
G92 E0
G1 X20 Y20 Z0.7 E0.5
G1 X40 Y20 Z0.7 E1.0
G92 E0
G1 X40 Y40 Z0.7 E0.5

; ============================================================
; 7. ARCS (G2/G3) mit I/J
; ============================================================
G1 X30 Y20 Z0.8 E2.0
G2 X40 Y10 I10 J-10 E3.0 ; CW arc
G1 X50 Y20 Z0.8 E4.0
G3 X60 Y10 I10 J-10 E5.0 ; CCW arc

; ============================================================
; 8. RETRACT / UNRETRACT
; ============================================================
G1 X50 Y50 Z0.9 E6.0
G10 ; retract
G0 X70 Y50 Z1.0 ; travel while retracted
G11 ; unretract
G1 X70 Y60 Z1 E3.25

; ============================================================
; 9. NEGATIVE E-WERTE (Retract durch negatives E)
; ============================================================
G1 X80 Y50 Z1.1 E3.5
G1 X80 Y50 Z1.1 E-0.5 ; negativer E-Wert = Retract
G0 X90 Y50 Z1.2 ; travel
G11 ; unretract
G1 X90 Y60 Z1.2 E4

; ============================================================
; 10. WIPE-ÄHNLICHE BEWEGUNG (großer XY-Sprung + positives E)
; ============================================================
G1 X10 Y10 Z1.3 E8.0
G1 X90 Y90 Z1.3 E4.25 ; großer Sprung + Extrusion = Wipe-Kandidat
G92 E0 ; reset E after wipe test

; ============================================================
; 11. SCIENTIFIC NOTATION
; ============================================================
G1 X0.0001 Y0.0002 Z2 E0.0005
G1 X1e2 Y2e2 Z2.1 E0.0075

; ============================================================
; 12. G2/G3 mit RELATIVEN KOORDINATEN (G91)
; ============================================================
G91 ; relative positioning
G1 X10 Y0 Z0 E0.05
G2 X0 Y10 I0 J10 E0.1
G90 ; back to absolute

; ============================================================
; 13. MEHRERE PARAMETER, GEMISCHTE REIHENFOLGE
; ============================================================
G1 F3000 X100 Y100 Z3 E5
G1 X110 Y100 E5.25 F6000
G1 Y110 E5.5 ; nur Y + E

; ============================================================
; 14. KOMMENTAR MIT SEMIKOLON IN PARAMETERNÄHE
; ============================================================
G1 X120 Y120 E6 ; das ist ein Kommentar
G1 X130 Y130 E6.25 ; Kommentar mit Zahl 123

; ============================================================
; 15. KLAMMER-KOMMENTARE (Slic3r-kompatibel)
; ============================================================
G1 X140 Y140 E6.5 (das ist ein Klammerkommentar)
G1 X150 Y150 E6.75 (XY-Klammer)

; ============================================================
; 16. LEERE ZEILEN UND NUR-KOMMENTAR
; ============================================================

; nackter Kommentar

; ============================================================
; 17. G2/G3 mit I/J = 0
; ============================================================
G1 X50 Y50 Z4 E7
G2 X50 Y60 I0 J10 E7.5
G3 X50 Y70 I0 J-10 E8

; ============================================================
; 18. LAYER WECHSEL OHNE TYP
; ============================================================
;LAYER_CHANGE
; layer:2
G1 X20 Y20 Z4.1 E8.5
G1 X40 Y20 Z4.1 E9

; ============================================================
; 19. TYPE-KOMMENTARE
; ============================================================
;TYPE:WALL-OUTER
G1 X60 Y20 Z4.2 E9.5
;TYPE:WALL-INNER
G1 X80 Y20 Z4.2 E10
;TYPE:FILL
G1 X100 Y20 Z4.3 E10.5
;TYPE:SUPPORT
G1 X120 Y20 Z4.3 E11
;TYPE:SKIN
G1 X140 Y20 Z4.4 E11.5

; ============================================================
; 20. MEHRERE G1-BEFEHLE PRO ZEILE (ungültig, aber robust)
; ============================================================
G1 X10 Y10 E12.5 G1 X20 Y20 E12.5

; ============================================================
; ENDE
; ============================================================
M104 S0 ; turn off temperature
M84 ; disable motors